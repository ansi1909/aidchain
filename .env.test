# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET=genera_un_app_secret_seguro_para_tests

# Base de datos aislada para los tests. Doctrine (config/packages/doctrine.yaml,
# bloque when@test) añade el sufijo "_test", por lo que la base efectiva es
# "aidchain_test" y nunca toca los datos de desarrollo.
DATABASE_URL="mysql://usuario:clave@127.0.0.1:3306/aidchain?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
